# ============================================================
#  telegram-iq-bot  —  plantilla de configuracion
#  Copia este archivo a  .env  y rellena los valores reales.
#  NUNCA subas .env al repo (esta en .gitignore).
# ============================================================

# ---- Telethon (leer el canal del senalero) ----
# my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=
# username (@canal) o id numerico del canal a escuchar (privado: -100XXXXXXXXXX)
TG_CHANNEL=
# nombre del archivo de sesion de telethon (se crea solo en el primer login)
TG_SESSION=telegram_signal_listener

# ---- IQ Option (broker: turbo options 5 min) ----
IQ_EMAIL=
IQ_PASSWORD=
# practice = demo (recomendado para validar) | real = dinero real
IQ_ACCOUNT_TYPE=practice

# ---- Bot propio de avisos (BotFather) ----
NOTIFY_BOT_TOKEN=
# chat id de Esteban (numerico). Sacar con @userinfobot o getUpdates.
NOTIFY_CHAT_ID=

# ---- Parametros de trading ----
# Stake de la entrada (USD). Las apuestas de Gale se derivan por formula (§4).
INITIAL_STAKE=1.00

# Zona horaria de la HORA de la senal. UTC-3 sin DST relevante.
SIGNAL_TIMEZONE=America/Sao_Paulo

# Zona para mostrar la hora "local" de Esteban en los avisos.
DISPLAY_TIMEZONE=America/Bogota

# Redondeo de la apuesta de Gale al centavo:
#   ceil    = redondea hacia ARRIBA  -> $2.12 / $4.47  (regla §4.1 "nunca quedar corto")  [default]
#   nearest = redondeo al mas cercano -> $2.11 / $4.46  (tabla de referencia §4.2 / §13.4)
GALE_ROUNDING=ceil

# Circuit breaker: None = DESACTIVADO (default). Un numero (ej. 50) = parar bajo ese balance.
STOP_LOSS_BALANCE=None

# Si la senal ya vencio, ¿cuanto en el pasado se considera "vencida" vs "es de manana"?
# Por encima de este margen (horas) se asume que la HH:MM es del dia siguiente.
STALE_SIGNAL_HOURS=12

# ---- Rutas de logs (opcional; defaults razonables) ----
LOG_DIR=logs

# ============================================================
#  Multicanal (proveedores extra). 0/vacio = desactivado.
#  Todos tienen defaults razonables en config.py; esto es solo override opcional.
# ============================================================
# CONSISTENTES VIP (lista diaria, UTC-5, M1+M5, whitelist + filtro de tendencia)
TG_CH_CONSISTENTES=
TZ_CONSISTENTES=America/Bogota
GALE_CONSISTENTES=2
STAKE_CONSISTENTES=6.00
# GOLD TRADER (lista diaria, UTC-3, M1+M5, sin martingala)
TG_CH_GOLD=
TZ_GOLD=America/Sao_Paulo
GALE_GOLD=0
STAKE_GOLD=10.00
# Filtro de tendencia (EMA rapida/lenta en la TF de la senal)
TREND_EMA_FAST=9
TREND_EMA_SLOW=21
# Stakes por bucket del canal 'main' (override; defaults en config.py)
STAKE_ALTO=8.00
STAKE_REAL=5.00
STAKE_OTC=3.00
